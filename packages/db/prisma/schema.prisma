generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PersonType {
  investor
  broker
}

enum DealScore {
  green
  yellow
  red
}

model Person {
  id        String     @id @default(uuid()) @db.Uuid
  type      PersonType
  firstName String     @map("first_name")
  lastName  String     @map("last_name")
  email     String     @unique
  phone     String?
  company   String?
  deals     Deal[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("persons")
}

model Deal {
  id             String    @id @default(uuid()) @db.Uuid
  person         Person    @relation(fields: [personId], references: [id])
  personId       String    @map("person_id") @db.Uuid
  productLane    String    @map("product_lane") // dscr, flip, str, multifamily
  leadType       String    @map("lead_type") // investor, broker
  channel        String    @default("web") // web, referral, ad
  utmSource      String?   @map("utm_source")
  utmMedium      String?   @map("utm_medium")
  utmCampaign    String?   @map("utm_campaign")

  // Property
  propertyAddress String?  @map("property_address")
  propertyCity    String?  @map("property_city")
  propertyState   String?  @map("property_state")
  propertyZip     String?  @map("property_zip")
  propertyType    String?  @map("property_type")
  units           Int?

  // Lane-specific inputs stored as JSON
  financials     Json?     @db.JsonB

  // AI triage results
  aiTriageResult Json?     @map("ai_triage_result") @db.JsonB
  dealScore      DealScore? @map("deal_score")

  // Monday.com sync
  mondayItemId   String?   @map("monday_item_id")

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("deals")
}

model Lender {
  id            String   @id @default(uuid()) @db.Uuid
  mondayItemId  String   @unique @map("monday_item_id") // sync tracking
  name          String
  productType   String?  @map("product_type")
  minFico       Int?     @map("min_fico")
  minDscr       Float?   @map("min_dscr")
  maxLtv        Float?   @map("max_ltv")
  maxLtc        Float?   @map("max_ltc")
  minLoan       Float?   @map("min_loan")
  maxLoan       Float?   @map("max_loan")
  maxUnits      Int?     @map("max_units")
  geography     Json?    @db.JsonB // { states: ["CA","TX",...] }
  notes         String?
  keyContact    String?  @map("key_contact")
  contactEmail  String?  @map("contact_email")
  rateRange     String?  @map("rate_range")
  prepayOptions String?  @map("prepay_options")
  uwFee         Float?   @map("uw_fee")
  syncedAt      DateTime @default(now()) @map("synced_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("lenders")
}

// ─── Market Data Models (AI Appraisal Cloud) ──────────

model County {
  id           String   @id @default(uuid()) @db.Uuid
  fips         String   @unique // 5-digit FIPS code
  name         String
  state        String   @db.VarChar(2)
  geography    Json?    @db.JsonB // { centroid, boundingBox }
  population   Int?
  medianIncome Float?   @map("median_income")

  marketSnapshots MarketDataSnapshot[]
  comparableSales ComparableSale[]
  marketBands     MarketBand[]

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([state])
  @@map("counties")
}

model MarketDataSnapshot {
  id              String   @id @default(uuid()) @db.Uuid
  county          County   @relation(fields: [countyId], references: [id])
  countyId        String   @map("county_id") @db.Uuid
  propertyType    String   @map("property_type")
  snapshotDate    DateTime @map("snapshot_date") @db.Date
  medianSalePrice Float?   @map("median_sale_price")
  medianPriceSqFt Float?   @map("median_price_sqft")
  medianRent      Float?   @map("median_rent")
  medianDom       Int?     @map("median_dom")
  inventoryMonths Float?   @map("inventory_months")
  yoyAppreciation Float?   @map("yoy_appreciation")
  activeListings  Int?     @map("active_listings")
  closedSales     Int?     @map("closed_sales")
  rawPayload      Json?    @map("raw_payload") @db.JsonB
  source          String?

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([countyId, propertyType, snapshotDate])
  @@map("market_data_snapshots")
}

model ComparableSale {
  id           String   @id @default(uuid()) @db.Uuid
  county       County   @relation(fields: [countyId], references: [id])
  countyId     String   @map("county_id") @db.Uuid
  address      String
  city         String?
  state        String?  @db.VarChar(2)
  zip          String?
  propertyType String   @map("property_type")
  units        Int?
  bedrooms     Int?
  bathrooms    Float?
  squareFeet   Int?     @map("square_feet")
  yearBuilt    Int?     @map("year_built")
  lotSize      Float?   @map("lot_size")
  salePrice    Float    @map("sale_price")
  saleDate     DateTime @map("sale_date") @db.Date
  pricePerSqFt Float?   @map("price_per_sqft")
  daysOnMarket Int?     @map("days_on_market")
  listPrice    Float?   @map("list_price")
  source       String?
  sourceId     String?  @map("source_id")
  latitude     Float?
  longitude    Float?
  rawPayload   Json?    @map("raw_payload") @db.JsonB

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([countyId, propertyType, saleDate])
  @@index([zip])
  @@index([state, city])
  @@map("comparable_sales")
}

model MarketBand {
  id              String   @id @default(uuid()) @db.Uuid
  county          County   @relation(fields: [countyId], references: [id])
  countyId        String   @map("county_id") @db.Uuid
  propertyType    String   @map("property_type")
  bandType        String   @map("band_type") // price, rent, cap_rate, price_per_sqft
  lowValue        Float    @map("low_value")
  midValue        Float    @map("mid_value")
  highValue       Float    @map("high_value")
  confidenceLevel String   @map("confidence_level") @default("moderate")
  sampleSize      Int?     @map("sample_size")
  asOfDate        DateTime @map("as_of_date") @db.Date
  source          String?

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([countyId, propertyType, bandType])
  @@map("market_bands")
}
