{
  "name": "@818capital/db",
  "version": "1.0.0",
  "private": true,
  "main": "./index.ts",
  "types": "./index.ts",
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "push": "prisma db push",
    "studio": "prisma studio",
    "build": "tsc",
    "seed": "tsx prisma/seed.ts",
    "generate:local": "npx dotenv-cli -e ../../.env -- prisma generate",
    "migrate:local": "npx dotenv-cli -e ../../.env -- prisma migrate dev",
    "push:local": "npx dotenv-cli -e ../../.env -- prisma db push",
    "studio:local": "npx dotenv-cli -e ../../.env -- prisma studio",
    "seed:local": "npx dotenv-cli -e ../../.env -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
